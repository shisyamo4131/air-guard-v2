rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 警備日報写真
    // - 認証済みユーザーであれば読み書き可能
    match /Companies/{companyId}/SiteOperationSchedules/{scheduleId}/SecurityReports/{file} {
      allow read, write: if request.auth != null;
    }

    // その他のパスはすべて拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
